# ── 🦉 Hypatia Sims4ModGuard API — Environment Configuration ─────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── Required for AI-powered log analysis ─────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Required for /submit-conflict GitHub issue creation ───────────────────────
# Create a fine-grained Personal Access Token at https://github.com/settings/tokens
# Permissions needed: Issues → Read & Write for HuciferX/Sims4ModGuard
GITHUB_TOKEN=your_github_token_here

# ── Optional service configuration ───────────────────────────────────────────
# Port the service listens on (default: 8765)
PORT=8765

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
